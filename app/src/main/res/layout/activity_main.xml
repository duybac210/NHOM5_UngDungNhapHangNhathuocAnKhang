<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/frame_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Thanh điều hướng tùy chỉnh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#dff7fb"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:id="@+id/nav_tab_orders"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:background="@drawable/nav_item_selectable_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_orders"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_orders"
                app:tint="#5cc849" />

            <TextView
                android:id="@+id/tv_nav_orders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:text="Đơn hàng"
                android:textColor="#5cc849"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tab_products"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:background="@drawable/nav_item_selectable_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_products"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_products"
                app:tint="#000000" />

            <TextView
                android:id="@+id/tv_nav_products"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:text="Sản phẩm"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tab_batches"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:background="@drawable/nav_item_selectable_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_batches"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_batches"
                app:tint="#000000" />

            <TextView
                android:id="@+id/tv_nav_batches"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:text="Lô hàng"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tab_suppliers"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1.2"
            android:layout_margin="2dp"
            android:background="@drawable/nav_item_selectable_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_suppliers"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_suppliers"
                app:tint="#000000" />

            <TextView
                android:id="@+id/tv_nav_suppliers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:text="Nhà cung cấp"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tab_manage"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:background="@drawable/nav_item_selectable_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_manage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_manage"
                app:tint="#000000" />

            <TextView
                android:id="@+id/tv_nav_manage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:text="Quản lý"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>