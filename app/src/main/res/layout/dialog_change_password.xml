<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Đổi mật khẩu"
        android:textColor="@color/login_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Current Password (for Re-authentication) -->
    <TextView
        android:id="@+id/tvCurrentPasswordLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Xác nhận mật khẩu hiện tại"
        android:textColor="#EE0000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <RelativeLayout
        android:id="@+id/layoutCurrentPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_login"
        android:paddingHorizontal="16dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivLockIcon0"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_lock"
            app:tint="#EE0000" />

        <EditText
            android:id="@+id/etCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/ivLockIcon0"
            android:background="@android:color/transparent"
            android:hint="Nhập mật khẩu hiện tại"
            android:inputType="textPassword"
            android:textColor="@color/login_text_body"
            android:textSize="16sp" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Mật khẩu mới"
        android:textColor="#666666"
        android:textSize="14sp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_login"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivLockIcon1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_lock"
            app:tint="@color/login_primary" />

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/ivLockIcon1"
            android:layout_toStartOf="@id/ivEyeIcon1"
            android:background="@android:color/transparent"
            android:hint="Nhập mật khẩu mới"
            android:inputType="textPassword"
            android:textColor="@color/login_text_body"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivEyeIcon1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:alpha="0.5"
            android:src="@drawable/ic_eye_off"
            app:tint="@color/login_text_body" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Nhập lại mật khẩu mới"
        android:textColor="#666666"
        android:textSize="14sp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_login"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivLockIcon2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_lock"
            app:tint="@color/login_primary" />

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/ivLockIcon2"
            android:layout_toStartOf="@id/ivEyeIcon2"
            android:background="@android:color/transparent"
            android:hint="Nhập lại mật khẩu mới"
            android:inputType="textPassword"
            android:textColor="@color/login_text_body"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/ivEyeIcon2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:alpha="0.5"
            android:src="@drawable/ic_eye_off"
            app:tint="@color/login_text_body" />
    </RelativeLayout>

    <Button
        android:id="@+id/btnSavePassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_button_login"
        android:enabled="false"
        android:text="Lưu"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>