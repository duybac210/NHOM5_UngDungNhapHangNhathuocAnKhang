<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    android:orientation="vertical"
    tools:ignore="HardcodedText,Autofill,TouchTargetSizeCheck,ButtonStyle">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#34D058"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:contentDescription="Quay lại"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Tạo Sản Phẩm"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thông tin cơ bản -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#BCB2B2"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Row 1: Tên thuốc | Thời gian tạo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên thuốc" android:textStyle="bold" android:textColor="#333333" android:textSize="13sp"/>
                            <EditText android:id="@+id/etProductName" android:layout_width="match_parent" android:layout_height="48dp" android:minHeight="48dp" android:background="@drawable/bg_field_outline" android:layout_marginTop="4dp" android:hint="Nhập tên thuốc" android:inputType="textCapWords" android:textColor="@color/black" android:textColorHint="#757575" android:textSize="13sp" android:paddingHorizontal="8dp" tools:ignore="TouchTargetSizeCheck"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#BCB2B2"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thời gian tạo" android:textStyle="bold" android:textColor="#333333" android:textSize="13sp"/>
                            <EditText android:id="@+id/etCreatedTime" android:layout_width="match_parent" android:layout_height="48dp" android:minHeight="48dp" android:background="@drawable/bg_field_outline" android:layout_marginTop="4dp" android:hint="Tự động tạo" android:textColor="@color/black" android:textColorHint="#757575" android:textSize="13sp" android:paddingHorizontal="8dp" android:focusable="false" tools:ignore="TouchTargetSizeCheck"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#BCB2B2"/>

                    <!-- Row 2: Giá vốn | Giá bán -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giá vốn" android:textStyle="bold" android:textColor="#333333" android:textSize="13sp"/>
                            <EditText android:id="@+id/etCostPrice" android:layout_width="match_parent" android:layout_height="48dp" android:minHeight="48dp" android:background="@drawable/bg_field_outline" android:layout_marginTop="4dp" android:hint="0" android:textColor="@color/black" android:textColorHint="#757575" android:textSize="13sp" android:paddingHorizontal="8dp" android:inputType="numberDecimal" tools:ignore="TouchTargetSizeCheck"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#BCB2B2"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giá bán" android:textStyle="bold" android:textColor="#333333" android:textSize="13sp"/>
                            <EditText android:id="@+id/etSellingPrice" android:layout_width="match_parent" android:layout_height="48dp" android:minHeight="48dp" android:background="@drawable/bg_field_outline" android:layout_marginTop="4dp" android:hint="0" android:textColor="@color/black" android:textColorHint="#757575" android:textSize="13sp" android:paddingHorizontal="8dp" android:inputType="numberDecimal" tools:ignore="TouchTargetSizeCheck"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin thuốc"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Card Thông tin sản xuất -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#BCB2B2"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hãng sản xuất" android:textStyle="bold" android:textColor="#333333" android:textSize="13sp"/>
                        <EditText android:id="@+id/etManufacturer" android:layout_width="match_parent" android:layout_height="48dp" android:minHeight="48dp" android:background="@drawable/bg_field_outline" android:hint="Nhập hãng sản xuất" android:layout_marginTop="8dp" android:inputType="textCapWords" android:textColor="@color/black" android:textColorHint="#757575" android:textSize="13sp" android:paddingHorizontal="8dp" tools:ignore="TouchTargetSizeCheck"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#BCB2B2"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nước sản xuất" android:textStyle="bold" android:textColor="#333333" android:textSize="13sp"/>
                        <EditText android:id="@+id/etCountry" android:layout_width="match_parent" android:layout_height="48dp" android:minHeight="48dp" android:background="@drawable/bg_field_outline" android:hint="Nhập nước sản xuất" android:layout_marginTop="8dp" android:inputType="textCapWords" android:textColor="@color/black" android:textColorHint="#757575" android:textSize="13sp" android:paddingHorizontal="8dp" tools:ignore="TouchTargetSizeCheck"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <LinearLayout
            android:id="@+id/bottomActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Bỏ qua"
                android:textAllCaps="false"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                app:strokeColor="@color/black"
                app:strokeWidth="1dp"
                app:cornerRadius="5dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:backgroundTint="#34D058"
                android:text="Lưu"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:cornerRadius="5dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
