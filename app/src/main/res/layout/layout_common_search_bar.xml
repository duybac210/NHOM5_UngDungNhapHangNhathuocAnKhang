<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Search Bar Section with Add Button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        tools:ignore="Autofill,MissingAutofillHint"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Search Box -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panel_orders"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:gravity="center_vertical"
            android:background="@drawable/search_bg_rounded"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnAddNew"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/search_hint_generic"
                android:textColorHint="#64748b"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:autofillHints="text"
                android:importantForAutofill="no"
                android:paddingStart="11dp"
                android:paddingEnd="11dp"
                tools:ignore="Autofill,MissingAutofillHint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivSearchIcon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/ivSearchIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#64748b"
                android:contentDescription="@null"
                tools:ignore="ContentDescription,MissingContentDescription"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Nút Thêm Mới (Đã bỏ màu nền) -->
        <ImageButton
            android:id="@+id/btnAddNew"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add"
            app:tint="#444444"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="@string/add_new_desc"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="4dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_marginStart="5dp"
        android:paddingBottom="10dp"
        android:text="@string/search_bar_title_orders"
        android:textSize="14sp"
        android:textColor="#000000"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/llSearchContainer"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>