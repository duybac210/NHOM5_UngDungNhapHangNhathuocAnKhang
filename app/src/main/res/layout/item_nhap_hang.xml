<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvMaDon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="13sp"
                android:gravity="center" />
            <View
                android:id="@+id/lineMaDon"
                android:layout_width="45dp"
                android:layout_height="1.2dp"
                android:background="#2196f3"
                android:visibility="gone" />
        </LinearLayout>
        <TextView android:id="@+id/tvNgayNhap" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.1" android:textColor="#000000" android:textSize="13sp" android:gravity="center" />
        <TextView android:id="@+id/tvTongTien" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:textColor="#000000" android:textSize="13sp" android:gravity="center" />
        <TextView android:id="@+id/tvTrangThai" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.4" android:textColor="#000000" android:textSize="13sp" android:paddingStart="12dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/expandableDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#F9F9F9">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_detail_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="95dp" android:layout_height="wrap_content" android:text="Người nhập:" android:textSize="11sp" android:textColor="#666666"/>
                <TextView android:id="@+id/tvNguoiNhapDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_field_outline" android:padding="3dp" android:textStyle="bold" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="95dp" android:layout_height="wrap_content" android:text="Ngày nhập:" android:textSize="11sp" android:textColor="#666666"/>
                <TextView android:id="@+id/tvNgayNhapDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_field_outline" android:padding="3dp" android:textStyle="bold" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="95dp" android:layout_height="wrap_content" android:text="Nhà cung cấp:" android:textSize="11sp" android:textColor="#666666"/>
                <TextView android:id="@+id/tvNhaCungCapDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_field_outline" android:padding="3dp" android:textStyle="bold" android:textSize="11sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="12dp"/>

            <LinearLayout android:id="@+id/llChiTietHang" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical" />

            <!-- Nút bấm sử dụng AppCompatButton để tránh lỗi màu tím của MaterialTheme -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnXoaDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_button_cancel_pill"
                    android:text="Hủy"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:drawableStart="@drawable/ic_delete"
                    android:drawablePadding="6dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp"
                    android:drawableTint="#FFFFFF" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSuaDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_button_edit_pill"
                    android:text="Sửa"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:drawableStart="@drawable/ic_edit"
                    android:drawablePadding="6dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp"
                    android:drawableTint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>
</LinearLayout>