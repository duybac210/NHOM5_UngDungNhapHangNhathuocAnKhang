<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_white"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sửa hàng hóa"
            android:textColor="#212529"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#495057" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="16dp"
        android:background="#F1F3F5" />

    <!-- Mã hàng & Mã vạch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Mã hàng"
                android:textColor="#495057"
                android:textSize="13sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_ma_hang"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_gray"
                android:enabled="false"
                android:paddingStart="12dp"
                android:textColor="#adb5bd"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Mã vạch"
                android:textColor="#495057"
                android:textSize="13sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_ma_vach"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_gray"
                android:hint="Nhập mã vạch"
                android:paddingStart="12dp"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tên hàng -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:text="Tên hàng"
        android:textColor="#495057"
        android:textSize="13sp"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/et_ten_hang"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_input_gray"
        android:paddingStart="12dp"
        android:textSize="14sp" />

    <!-- Giá vốn -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:text="Giá vốn"
        android:textColor="#495057"
        android:textSize="13sp"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/et_gia_von"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_input_gray"
        android:inputType="numberDecimal"
        android:paddingStart="12dp"
        android:textSize="14sp" />

    <!-- Group Thông tin khác -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input_gray"
        android:backgroundTint="#FDFDFD"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Thông tin khác"
            android:textColor="#212529"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Hãng sản xuất"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_hang_sx"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_gray"
                    android:backgroundTint="#FFFFFF"
                    android:hint="Nhập hãng SX"
                    android:paddingStart="10dp"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Nước sản xuất"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_nuoc_sx"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_gray"
                    android:backgroundTint="#FFFFFF"
                    android:hint="Nhập nước SX"
                    android:paddingStart="10dp"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Footer Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bỏ qua"
            android:textAllCaps="false"
            android:textColor="#868E96" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:backgroundTint="#007BFF"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Lưu"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
